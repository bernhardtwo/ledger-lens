{
  "name": "@ledger-lens/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "start": "node --env-file=../../.env --import tsx ./src/http/main.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=../../.env --import tsx ./src/db/migrate.ts",
    "db:seed": "node --env-file=../../.env --import tsx ./src/db/seed.ts",
    "smoke:categorize": "node --env-file=../../.env --import tsx ./src/categorization/smoke.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "@ledger-lens/shared": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "csv-parse": "^5.5.6",
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@testcontainers/postgresql": "^10.16.0",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.28.1",
    "supertest": "^7.0.0",
    "testcontainers": "^10.16.0",
    "tsx": "^4.19.2"
  }
}
