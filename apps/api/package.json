{
  "name": "@ledger-lens/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "start": "node --env-file=../../.env --import tsx ./src/http/main.ts",
    "dev": "node --env-file=../../.env --import tsx ./src/http/main.ts",
    "smoke:categorize": "node --env-file=../../.env --import tsx ./src/categorization/smoke.ts",
    "smoke:ask": "node --env-file=../../.env --import tsx ./src/agent/smoke.ts",
    "smoke:ask-stream": "node --env-file=../../.env --import tsx ./src/agent/smoke-stream.ts",
    "eval": "node --env-file-if-exists=../../.env --import tsx ./src/evals/run-eval.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.168",
    "@anthropic-ai/sdk": "^0.69.0",
    "@azure/monitor-opentelemetry": "^1.18.1",
    "@ledger-lens/db": "workspace:*",
    "@ledger-lens/evals": "workspace:*",
    "@ledger-lens/mcp-server": "workspace:*",
    "@ledger-lens/shared": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@opentelemetry/api": "^1.9.1",
    "csv-parse": "^5.5.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.19.0",
    "@nestjs/testing": "^10.4.15",
    "@opentelemetry/context-async-hooks": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@testcontainers/postgresql": "^10.16.0",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "testcontainers": "^10.16.0",
    "tsx": "^4.19.2"
  }
}
