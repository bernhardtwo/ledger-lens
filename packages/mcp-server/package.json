{
  "name": "@ledger-lens/mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "ledgerlens-dist": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./stdio": {
      "ledgerlens-dist": "./dist/main.js",
      "default": "./src/main.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "start": "node --env-file=../../.env --import tsx ./src/main.ts"
  },
  "dependencies": {
    "@ledger-lens/db": "workspace:*",
    "@ledger-lens/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.19.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.16.0",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2"
  }
}
