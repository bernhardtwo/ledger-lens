{
  "name": "@ledger-lens/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=../../.env --import tsx ./src/migrate.ts",
    "db:seed": "node --env-file=../../.env --import tsx ./src/seed.ts"
  },
  "dependencies": {
    "@ledger-lens/shared": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.16.0",
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.28.1",
    "testcontainers": "^10.16.0",
    "tsx": "^4.19.2"
  }
}
