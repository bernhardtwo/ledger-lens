# ---- PostgreSQL (docker-compose) ----
POSTGRES_USER=ledgerlens
POSTGRES_PASSWORD=ledgerlens
POSTGRES_DB=ledgerlens
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ledgerlens:ledgerlens@localhost:5432/ledgerlens

# ---- Claude API (used from Phase 2 onward) ----
# NEVER expose this to the browser. Server-side only.
ANTHROPIC_API_KEY=
# Parametrised so the codebase is not coupled to a single model.
ANTHROPIC_MODEL=claude-opus-4-8
