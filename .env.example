# ---- PostgreSQL (docker-compose) ----
POSTGRES_USER=ledgerlens
POSTGRES_PASSWORD=ledgerlens
POSTGRES_DB=ledgerlens
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ledgerlens:ledgerlens@localhost:5432/ledgerlens

# ---- Claude API (used from Phase 2 onward) ----
# NEVER expose this to the browser. Server-side only.
ANTHROPIC_API_KEY=
# Phase 2 — transaction categorization (cheap, high-volume classification).
ANTHROPIC_CATEGORIZATION_MODEL=claude-haiku-4-5
# Optional: transactions per categorization API call (default 50).
ANTHROPIC_CATEGORIZATION_BATCH_SIZE=50
# Phase 4 — Q&A agent (orchestrates the read-only MCP tools). Haiku is the v1
# default; flip to a stronger model (e.g. claude-sonnet-4-6) if Phase 5 evals say so.
ANTHROPIC_AGENT_MODEL=claude-haiku-4-5
# Optional: agentic turn cap per question (bounds loops/cost; default 8).
ANTHROPIC_AGENT_MAX_TURNS=8
# Optional: per-question budget guardrail in USD (default 0.15).
ANTHROPIC_AGENT_MAX_BUDGET_USD=0.15

# ---- Phase 5 — eval harness (`pnpm eval`) ----
# Runs the REAL agent against the golden dataset, so it spends tokens — it is a
# manual/scheduled job, never part of `pnpm check`. It builds its OWN ephemeral
# Postgres each run (testcontainers), so it needs only ANTHROPIC_API_KEY and a
# running Docker — NOT DATABASE_URL. It reuses the ANTHROPIC_AGENT_* vars above.
# Compare models with `pnpm eval -- --models claude-haiku-4-5,claude-sonnet-4-6`;
# the optional LLM-as-judge is opt-in with `--judge` (off by default, reported-only).
